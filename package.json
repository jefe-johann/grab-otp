{
  "name": "grab-otp-extension",
  "version": "1.0.1",
  "description": "Browser extension to automatically retrieve OTP codes from Gmail",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "vite build --mode production --outDir dist/chrome",
    "build:firefox": "TARGET=firefox vite build --mode production --outDir dist/firefox",
    "sign:firefox": "web-ext sign --source-dir=dist/firefox --artifacts-dir=signed-packages --channel=unlisted",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/webextension-polyfill": "^0.10.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^8.57.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "web-ext": "^9.2.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.10.0"
  },
  "keywords": [
    "browser-extension",
    "otp",
    "gmail",
    "authentication",
    "webextension"
  ],
  "author": "",
  "license": "MIT"
}
