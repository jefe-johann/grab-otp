# OAuth Client IDs for Google API
# These should be set as environment variables for secure builds

# Chrome extension OAuth client ID and secret
CHROME_CLIENT_ID=your-chrome-client-id.apps.googleusercontent.com
CHROME_CLIENT_SECRET=your-chrome-client-secret

# Firefox extension OAuth client ID and secret
FIREFOX_CLIENT_ID=your-firefox-client-id.apps.googleusercontent.com
FIREFOX_CLIENT_SECRET=your-firefox-client-secret

# Client secrets are required for Web Application type OAuth clients
# to receive refresh tokens (needed for persistent login without re-auth).
# Get these from Google Cloud Console > APIs & Services > Credentials.

# For production builds, these MUST be set to your own OAuth credentials
